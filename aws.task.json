{
    "containerDefinitions": [
        {
            "name": "IERG4210-frontend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "ierg4210-frontend-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/IERG4210-task-frontend",
                    "awslogs-create-group": "true",
                    "awslogs-region": "ap-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "taskRoleArn": "arn:aws:iam::816069156976:role/ecsTaskExecutionRole",
    "executionRoleArn": "arn:aws:iam::816069156976:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}